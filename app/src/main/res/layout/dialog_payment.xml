<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivBankIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_bank"
        app:tint="@color/green"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvPaymentTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thanh toán gói AI"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivBankIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvPaymentDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vui lòng chuyển khoản đến tài khoản dưới đây với ĐÚNG nội dung chuyển khoản để hệ thống duyệt tự động."
        android:textAlignment="center"
        android:textColor="@color/grey"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvPaymentTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bank Details Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBankDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#F5F5F5"
        app:cardCornerRadius="8dp"
        app:contentPadding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvPaymentDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngân hàng: Vietcombank"
                android:textStyle="bold"
                android:textSize="16sp"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STK: 0123456789"
                android:layout_marginTop="4dp"
                android:textSize="16sp"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chủ TK: TRINH HOANG TU"
                android:layout_marginTop="4dp"
                android:textSize="16sp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Payment Code Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPaymentCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="#E8F5E9"
        app:strokeColor="@color/green"
        app:strokeWidth="1dp"
        app:cardCornerRadius="8dp"
        app:contentPadding="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardBankDetails"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NỘI DUNG CHUYỂN KHOẢN (BẮT BUỘC):"
                android:textColor="@color/green"
                android:textStyle="bold"
                android:textSize="12sp"/>
                
            <TextView
                android:id="@+id/tvPaymentCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PM-XXXXXX"
                android:layout_marginTop="8dp"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/black"
                android:letterSpacing="0.1"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardPaymentCode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Hủy"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmPaid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Tôi đã chuyển..." />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
